---
import Layout from '../layouts/Layout.astro';

const artworks = [
  { id: 1, title: "Serenity in Ink", category: "Painting", year: "2025", image: "https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?q=80&w=800&auto=format&fit=crop" },
  { id: 2, title: "Urban Echoes", category: "Mixed Media", year: "2024", image: "https://images.unsplash.com/photo-1541701494587-cb58502866ab?q=80&w=800&auto=format&fit=crop" },
  { id: 3, title: "The Silent Bamboo", category: "Digital Art", year: "2025", image: "https://images.unsplash.com/photo-1580136579312-94651dfd596d?q=80&w=800&auto=format&fit=crop" },
  { id: 4, title: "Fragments", category: "Design", year: "2024", image: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=800&auto=format&fit=crop" },
  { id: 5, title: "Whispers of the Past", category: "Painting", year: "2023", image: "https://images.unsplash.com/photo-1513364776144-60967b0f800f?q=80&w=800&auto=format&fit=crop" },
  { id: 6, title: "Structure & Flow", category: "Sketch", year: "2025", image: "https://images.unsplash.com/photo-1506744626753-1fa7604d459a?q=80&w=800&auto=format&fit=crop" }
];
---

<Layout title="Portfolio - Claire Zhang">
	<div class="mt-12 md:mt-24 mb-16">
		<h1 class="text-4xl md:text-6xl font-light mb-4">Selected Works</h1>
		<p class="text-gray-500 max-w-2xl">A collection of visual explorations bridging traditional aesthetics and modern design principles.</p>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
		{artworks.map((art) => (
			<div class="group cursor-pointer">
				<div class="relative overflow-hidden aspect-[4/5] bg-gray-100 mb-4">
					<img src={art.image} alt={art.title} class="object-cover w-full h-full transform group-hover:scale-105 transition-transform duration-700 ease-in-out opacity-90 group-hover:opacity-100" />
				</div>
				<h3 class="text-lg font-medium">{art.title}</h3>
				<div class="flex justify-between text-sm text-gray-500 mt-1 uppercase tracking-widest">
					<span>{art.category}</span>
					<span>{art.year}</span>
				</div>
			</div>
		))}
	</div>
</Layout>