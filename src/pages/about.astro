---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout title="About - Claire Zhang" description="Artist statement and background." path="about">
	<div class="grid grid-cols-1 md:grid-cols-12 gap-16 mt-12 md:mt-24 mb-24">
		
		<!-- Image -->
		<div class="md:col-span-5 relative">
			<div class="aspect-[3/4] bg-[#EDE8E1] overflow-hidden shadow-lg">
				<img src="/assets/art/placeholder-2.svg" alt="Claire Zhang" class="object-cover w-full h-full grayscale hover:grayscale-0 transition-all duration-1000" />
			</div>
			<div class="absolute -right-8 -bottom-8 w-48 h-48 border border-[#EDE8E1] -z-10 hidden md:block"></div>
		</div>

		<!-- Text Content -->
		<div class="md:col-span-7 flex flex-col justify-center">
			<h1 class="text-4xl md:text-6xl font-light mb-6">{site.profile.name}</h1>
			<p class="text-sm uppercase tracking-[0.25em] text-[#A9A39A] font-sans mb-6">
				Artist Statement
			</p>
			
			<div class="space-y-6 text-[#6f6963] leading-relaxed font-light text-lg">
				<p>
					I am a visual artist and musician based in Vancouver, currently studying at {site.profile.school}. My creative journey is an ongoing dialogue between two connected worlds: the structured discipline of visual design and the fluid emotionality of the Chinese Guzheng.
				</p>
				<p>
					Through years of Guzheng practice and performance, I learned how sound shapes space. This philosophy informs my art: the negative space—the blankness—is as vital as the subject. I aim to translate traditional Chinese aesthetics into contemporary visual communication.
				</p>
				<p>
					{site.profile.appIntent}
				</p>
			</div>

			<div class="mt-12 border-t border-[#EDE8E1] pt-10">
				<h3 class="text-xs uppercase tracking-[0.25em] text-[#A9A39A] mb-6 font-sans">Experience & Education</h3>
				<ul class="space-y-6 border-l border-[#EDE8E1] pl-6">
					{site.timeline.map((item) => (
						<li class="relative">
							<span class="absolute -left-[9px] top-1.5 w-3 h-3 bg-[#c93a3a] rounded-full"></span>
							<div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-2">
								<span class="font-medium text-[#1a1a1a]">{item.label}</span>
								<span class="text-xs text-[#A9A39A] font-serif italic">{item.year}</span>
							</div>
						</li>
					))}
				</ul>
			</div>

			<div class="mt-12">
				<h3 class="text-xs uppercase tracking-[0.25em] text-[#A9A39A] mb-4 font-sans">Focus Areas</h3>
				<div class="grid grid-cols-2 gap-4 text-sm text-[#6f6963]">
					{site.skills.map((s) => (
						<div class="border border-[#EDE8E1] px-3 py-2">{s}</div>
					))}
				</div>
			</div>

			<div class="mt-12">
				<a href={`mailto:${site.profile.email}`} class="inline-block border border-[#1a1a1a] px-8 py-3 text-xs tracking-[0.25em] uppercase hover:bg-[#1a1a1a] hover:text-white transition-colors duration-300 font-sans">
					Contact
				</a>
			</div>
		</div>

	</div>
</Layout>