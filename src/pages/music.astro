---
import Layout from '../layouts/Layout.astro';

const performances = [
  { id: 1, title: "Echoes of the Mountains", date: "Dec 2025", location: "Vancouver City Hall", videoUrl: "https://www.youtube.com/embed/dQw4w9WgXcQ?controls=0" },
  { id: 2, title: "Spring Awakening", date: "May 2024", location: "Semiahmoo Secondary", videoUrl: "https://www.youtube.com/embed/dQw4w9WgXcQ?controls=0" }
];
---

<Layout title="Music - Claire Zhang">
	<div class="mt-12 md:mt-24 mb-16 max-w-3xl">
		<h1 class="text-4xl md:text-6xl font-light mb-6">Music & Performance</h1>
		<p class="text-gray-600 leading-relaxed text-lg mb-8">
			The Guzheng (古筝) is not merely an instrument; it is a canvas of sound. With over [X] years of practice and performance, I explore the profound resonance of traditional Chinese music while seeking contemporary interpretations. The discipline of music deeply informs my approach to visual design—both require an understanding of rhythm, tension, and the beauty of negative space.
		</p>
	</div>

	<div class="space-y-24 mb-24">
		{performances.map((perf) => (
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
				<div class="md:col-span-8 bg-gray-100 aspect-video relative group overflow-hidden">
					<!-- Replace with actual video embed code or thumbnail later -->
					<div class="w-full h-full flex items-center justify-center text-gray-400 border border-gray-200">
						<span>[Video Placeholder: {perf.title}]</span>
					</div>
				</div>
				<div class="md:col-span-4">
					<h3 class="text-2xl font-medium mb-2">{perf.title}</h3>
					<div class="flex flex-col text-sm text-gray-500 uppercase tracking-widest space-y-2 mb-6">
						<span>{perf.date}</span>
						<span>{perf.location}</span>
					</div>
					<p class="text-gray-600 font-light text-sm">A brief description of this performance, the piece played, and its significance or emotional core.</p>
				</div>
			</div>
		))}
	</div>
</Layout>