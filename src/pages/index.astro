---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout
	title="Claire Zhang — Portfolio"
	description="Modern visual design rooted in traditional Chinese aesthetics."
	path=""
>
	<div class="absolute inset-0 -z-10">
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(132,24,24,0.30),transparent_45%),radial-gradient(circle_at_10%_20%,rgba(45,58,72,0.25),transparent_40%),radial-gradient(circle_at_30%_80%,rgba(210,210,210,0.25),transparent_35%)]"></div>
		<div class="absolute inset-0 bg-[linear-gradient(135deg,#2F3A48_0%,#2F3A48_40%,#F5F5F2_41%,#F5F5F2_100%)] opacity-95"></div>
	</div>

	<section class="min-h-[85vh] grid grid-cols-12 gap-8 items-center mt-12 md:mt-24 relative">
		<div class="hidden md:flex absolute -left-8 top-20 flex-col items-center text-[10px] tracking-[0.6em] text-[#841818] font-sans">
			<span class="[writing-mode:vertical-rl]">MODERN · ORIENTAL</span>
			<span class="mt-6 w-px h-20 bg-[#841818]/40"></span>
		</div>
		<div class="col-span-12 lg:col-span-7 z-10">
			<div class="flex items-center gap-4 mb-8">
				<span class="inline-flex items-center justify-center w-12 h-12 bg-[#841818] text-white font-sans text-xs tracking-[0.3em]">印</span>
				<span class="font-sans uppercase tracking-[0.4em] text-xs text-[#841818]">Claire Zhang</span>
			</div>

			<h1 class="text-6xl md:text-8xl lg:text-[9.5rem] leading-[0.85] font-light tracking-tighter text-[#2F3A48]">
				BOLD
				<span class="block text-[#841818] italic">EAST.</span>
				<span class="block text-[#2F3A48]">NEW</span>
				<span class="block text-[#2F3A48]">WEST.</span>
			</h1>

			<p class="mt-8 text-lg md:text-2xl font-light text-[#2F3A48] max-w-xl border-l-4 border-[#841818] pl-6">
				{site.profile.tagline}
			</p>

			<p class="mt-6 text-sm md:text-base text-[#4B5563] max-w-lg">
				Translating the rhythm of Guzheng into visual language—ink breath, quiet tension, and the elegance of negative space.
			</p>

			<div class="mt-10 flex flex-wrap gap-10 text-xs uppercase tracking-[0.35em] font-sans text-[#2F3A48]">
				<a href="/portfolio" class="group flex items-center gap-3">
					<span class="w-10 h-[2px] bg-[#2F3A48] group-hover:bg-[#841818] transition-all duration-500"></span>
					View Works
				</a>
				<a href="/music" class="group flex items-center gap-3">
					<span class="w-10 h-[2px] bg-[#2F3A48] group-hover:bg-[#841818] transition-all duration-500"></span>
					Listen
				</a>
			</div>
		</div>

		<div class="col-span-12 lg:col-span-5 relative h-[70vh]">
			<div class="absolute -top-10 -right-6 w-[120%] h-[120%] bg-[conic-gradient(from_90deg,rgba(132,24,24,0.25),transparent_40%,rgba(47,58,72,0.25),transparent_70%)] animate-spin-slow"></div>
			<div class="absolute -left-6 bottom-8 w-40 h-40 opacity-20">
				<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-full text-[#2F3A48]">
					<path fill="currentColor" d="M40.5,-69.5C52.7,-62.4,63.1,-52.6,70.7,-40.2C78.3,-27.7,83.1,-12.5,83.7,3.4C84.4,19.3,80.9,36,72.2,49.2C63.5,62.3,49.6,72,34.4,76.5C19.1,81,2.4,80.3,-13.4,75.6C-29.2,70.9,-44.2,62.3,-56.6,50.5C-69,38.8,-78.8,23.8,-81.1,7.1C-83.5,-9.6,-78.4,-27.1,-68.2,-40.5C-58,-53.9,-42.7,-63.2,-26.5,-69.4C-10.3,-75.6,6.8,-78.6,21.8,-76.6C36.8,-74.6,49.7,-67.7,40.5,-69.5Z"/>
				</svg>
			</div>
			<div class="absolute inset-0 bg-[#2F3A48] shadow-2xl overflow-hidden border-4 border-[#841818]">
				<div class="absolute inset-0 bg-[linear-gradient(0deg,rgba(0,0,0,0.45),transparent_60%)]"></div>
				<img src="/assets/art/placeholder-7.svg" alt="Featured work" class="object-cover w-full h-full mix-blend-screen opacity-90" />
				<div class="absolute top-4 left-4 text-white font-sans text-[10px] tracking-[0.3em]">SIGNATURE</div>
				<div class="absolute bottom-6 right-6 w-20 h-20 bg-[#841818] text-white font-sans text-3xl flex items-center justify-center rotate-[-8deg]">印</div>
			</div>
		</div>
	</section>

	<section class="mt-16 border-t-2 border-[#2F3A48] pt-12">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-sm text-[#2F3A48]">
			<div class="md:col-span-1">
				<h2 class="text-2xl font-light mb-2">Highlights</h2>
				<p class="text-xs uppercase tracking-[0.25em] text-[#841818] font-sans">{site.profile.appIntent}</p>
			</div>
			{site.highlights.map((h, i) => (
				<div class="border-l-2 border-[#841818] pl-6">
					<p class="text-5xl font-light mb-2 text-[#2F3A48]">0{i+1}</p>
					<p class="uppercase tracking-[0.25em] text-[#4B5563] font-sans">{h}</p>
				</div>
			))}
		</div>
	</section>

	<style>
		@keyframes spinSlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
		.animate-spin-slow { animation: spinSlow 40s linear infinite; }
		@media (prefers-reduced-motion: reduce) { .animate-spin-slow { animation: none; } }
	</style>
</Layout>