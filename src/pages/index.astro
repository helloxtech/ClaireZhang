---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Claire Zhang - Artist & Musician">
	<div class="h-[75vh] flex flex-col justify-center items-start md:w-2/3 mt-12 md:mt-24">
		<h1 class="text-5xl md:text-8xl font-light mb-6 tracking-tight text-gray-900 leading-tight">
			Where East <br/><span class="italic text-gray-500 font-serif">Meets West.</span>
		</h1>
		<p class="text-lg md:text-2xl font-light text-gray-600 mb-12 max-w-xl leading-relaxed">
			Exploring the intersection of modern visual design and traditional Guzheng performance.
		</p>
		<div class="flex space-x-8 text-sm uppercase tracking-[0.2em] font-medium text-gray-800">
			<a href="/portfolio" class="border-b border-transparent hover:border-black transition-all pb-1 duration-300">View Portfolio</a>
			<a href="/music" class="border-b border-transparent hover:border-[#c93a3a] text-[#c93a3a] transition-all pb-1 duration-300">Listen</a>
		</div>
	</div>
	
	<div class="absolute right-0 top-0 bottom-0 w-1/3 hidden md:flex items-center justify-center opacity-10 pointer-events-none overflow-hidden">
		<!-- Placeholder abstract ink element -->
		<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-[800px] h-[800px] absolute -right-32 fill-current text-gray-900">
