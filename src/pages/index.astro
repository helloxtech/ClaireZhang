---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout
	title="Claire Zhang — Portfolio"
	description="Modern visual design rooted in traditional Chinese aesthetics."
	path=""
>
	<section class="min-h-[60vh] md:min-h-[70vh] grid grid-cols-1 md:grid-cols-12 gap-12 items-center mt-8 md:mt-16">
		<div class="md:col-span-7">
			<h1 class="text-5xl md:text-8xl font-light mb-6 tracking-tight leading-tight">
				Modern visual design<br />
				<span class="italic text-[#A9A39A]">rooted in Chinese aesthetics.</span>
			</h1>
			<p class="text-lg md:text-2xl font-light text-[#6f6963] mb-8 max-w-xl leading-relaxed">
				{site.profile.tagline}
			</p>
			<div class="flex flex-wrap gap-8 text-xs uppercase tracking-[0.25em] font-sans text-[#1a1a1a]">
				<a href="/portfolio" class="border-b border-transparent hover:border-black transition-all pb-1 duration-300">View Selected Works</a>
				<a href="/music" class="border-b border-transparent hover:border-[#c93a3a] text-[#c93a3a] transition-all pb-1 duration-300">Listen to Guzheng</a>
			</div>
			<div class="mt-10 flex flex-wrap gap-8 text-xs uppercase tracking-[0.25em] text-[#A9A39A] font-sans">
				{site.highlights.map((h) => (
					<span>{h}</span>
				))}
			</div>
			<p class="mt-6 text-sm uppercase tracking-[0.2em] text-[#A9A39A] font-sans">
				{site.profile.appIntent}
			</p>
		</div>
		<div class="md:col-span-5">
			<div class="aspect-[4/5] bg-[#EDE8E1] overflow-hidden shadow-lg">
				<img src="/assets/art/placeholder-7.svg" alt="Featured work" class="object-cover w-full h-full opacity-95 hover:opacity-100 transition-opacity duration-700" />
			</div>
		</div>
	</section>

	<section class="mt-24 border-t border-[#EDE8E1] pt-16">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-[#6f6963]">
			<div>
				<p class="uppercase tracking-[0.2em] text-[#A9A39A] font-sans mb-2">Focus</p>
				<p>Visual design, illustration, cultural narratives.</p>
			</div>
			<div>
				<p class="uppercase tracking-[0.2em] text-[#A9A39A] font-sans mb-2">Mediums</p>
				<p>Ink, digital composition, mixed media.</p>
			</div>
			<div>
				<p class="uppercase tracking-[0.2em] text-[#A9A39A] font-sans mb-2">Location</p>
				<p>{site.profile.location}</p>
			</div>
		</div>
	</section>
</Layout>