---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout
	title="Claire Zhang — Portfolio"
	description="Modern visual design rooted in traditional Chinese aesthetics."
	path=""
>
	<section class="min-h-[60vh] md:min-h-[70vh] grid grid-cols-1 md:grid-cols-12 gap-12 items-center mt-8 md:mt-16">
		<div class="md:col-span-7">
			<h1 class="text-5xl md:text-8xl font-light mb-6 tracking-tight leading-tight">
				Modern visual design<br />
				<span class="italic text-[#A9A39A]">rooted in Chinese aesthetics.</span>
			</h1>
			<p class="text-lg md:text-2xl font-light text-[#6f6963] mb-6 max-w-xl leading-relaxed">
				{site.profile.tagline}
			</p>
			<p class="text-sm md:text-base text-[#6f6963] max-w-xl">
				I translate the rhythm of Guzheng into visual language—ink breath, quiet tension, and the elegance of negative space.
			</p>
			<div class="mt-8 flex flex-wrap gap-8 text-xs uppercase tracking-[0.25em] font-sans text-[#1a1a1a]">
				<a href="/portfolio" class="border-b border-transparent hover:border-black transition-all pb-1 duration-300">View Selected Works</a>
				<a href="/music" class="border-b border-transparent hover:border-[#c93a3a] text-[#c93a3a] transition-all pb-1 duration-300">Listen to Guzheng</a>
			</div>
			<div class="mt-10 flex flex-wrap gap-8 text-xs uppercase tracking-[0.25em] text-[#A9A39A] font-sans">
				{site.highlights.map((h) => (
					<span>{h}</span>
				))}
			</div>
			<p class="mt-6 text-sm uppercase tracking-[0.2em] text-[#A9A39A] font-sans">
				{site.profile.appIntent}
			</p>
		</div>
		<div class="md:col-span-5 relative">
			<div class="absolute -top-10 -right-6 w-40 h-40 opacity-20 animate-ink">
				<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-full text-[#1a1a1a]">
					<path fill="currentColor" d="M32.6,-58.1C43.5,-51,54.2,-44.4,62.6,-34.7C71,-25,77.1,-12.5,77.1,0C77.2,12.6,71.1,25.2,62.5,35.4C53.8,45.6,42.6,53.3,30.3,60.3C17.9,67.4,4.3,73.8,-9.7,76.2C-23.7,78.7,-38.2,77.2,-50.7,69.9C-63.2,62.6,-73.8,49.4,-78.1,34.5C-82.3,19.6,-80.1,2.9,-75.3,-12.2C-70.5,-27.4,-63.2,-41.1,-52.1,-49.5C-41,-57.8,-26.1,-60.8,-12.1,-61.7C1.9,-62.7,15.9,-61.6,32.6,-58.1Z"/>
				</svg>
			</div>
			<div class="aspect-[4/5] bg-[#EDE8E1] overflow-hidden shadow-lg relative">
				<div class="absolute inset-0 pointer-events-none">
					<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.16] animate-ink-slow text-[#1a1a1a]">
						<path fill="currentColor" d="M42.8,-69.8C55.6,-64.8,66.4,-55.2,73.2,-43.1C80,-31,82.8,-15.5,81.6,-0.7C80.4,14.1,75.1,28.2,66.5,39.2C57.9,50.3,46,58.4,33.3,65.7C20.6,73,7.2,79.4,-7.3,81.5C-21.7,83.6,-37.1,81.5,-48.8,73.2C-60.4,65,-68.2,50.5,-73.2,35.7C-78.3,20.8,-80.6,5.4,-78.2,-9.1C-75.8,-23.6,-68.6,-37.2,-57.8,-47.2C-47,-57.2,-32.6,-63.6,-17.6,-67.2C-2.6,-70.8,13,-71.6,28.4,-70.7C43.8,-69.8,59.1,-67.2,42.8,-69.8Z"/>
					</svg>
				</div>
				<div class="absolute inset-0 pointer-events-none">
					<div class="ripple r1"></div>
					<div class="ripple r2"></div>
					<div class="ripple r3"></div>
				</div>
				<img src="/assets/art/placeholder-7.svg" alt="Featured work" class="object-cover w-full h-full opacity-95 hover:opacity-100 transition-opacity duration-700" />
			</div>
			<div class="absolute -right-4 -bottom-4 w-16 h-16 border border-[#c93a3a] text-[#c93a3a] font-sans text-[10px] tracking-[0.3em] flex items-center justify-center">印</div>
		</div>

	<style>
		@keyframes inkFloat {
			0% { transform: translateY(0px) scale(1); opacity: 0.18; }
			50% { transform: translateY(-8px) scale(1.02); opacity: 0.28; }
			100% { transform: translateY(0px) scale(1); opacity: 0.18; }
		}
		@keyframes inkPulse {
			0% { transform: scale(1); opacity: 0.08; }
			50% { transform: scale(1.05); opacity: 0.18; }
			100% { transform: scale(1); opacity: 0.08; }
		}
		@keyframes ripple {
			0% { transform: scale(0.2); opacity: 0; }
			40% { opacity: 0.25; }
			100% { transform: scale(1.4); opacity: 0; }
		}
		.animate-ink { animation: inkFloat 8s ease-in-out infinite; }
		.animate-ink-slow { animation: inkPulse 10s ease-in-out infinite; }
		.ripple {
			position: absolute;
			inset: 12% 12%;
			border: 1px solid rgba(201, 58, 58, 0.25);
			border-radius: 50%;
			animation: ripple 6s ease-in-out infinite;
		}
		.ripple.r2 { animation-delay: 1.8s; inset: 18% 18%; }
		.ripple.r3 { animation-delay: 3.6s; inset: 24% 24%; }
	</style>
	</section>

	<section class="mt-24 border-t border-[#EDE8E1] pt-16">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-[#6f6963]">
			<div>
				<p class="uppercase tracking-[0.2em] text-[#A9A39A] font-sans mb-2">Focus</p>
				<p>Visual design, illustration, cultural narratives.</p>
			</div>
			<div>
				<p class="uppercase tracking-[0.2em] text-[#A9A39A] font-sans mb-2">Mediums</p>
				<p>Ink, digital composition, mixed media.</p>
			</div>
			<div>
				<p class="uppercase tracking-[0.2em] text-[#A9A39A] font-sans mb-2">Location</p>
				<p>{site.profile.location}</p>
			</div>
		</div>
	</section>
</Layout>