---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	path?: string;
}

const { title, description = 'Claire Zhang - Portfolio', path = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Noto+Serif+SC:wght@300;400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FAFAF7] text-[#1a1a1a] font-serif antialiased selection:bg-[#c93a3a] selection:text-white min-h-screen flex flex-col relative overflow-x-hidden">
		<a href="#main" class="sr-only focus:not-sr-only focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#c93a3a]">Skip to content</a>
		<div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.12] mix-blend-multiply" style="background-image:url('/assets/texture.svg');"></div>
		<div aria-hidden="true" class="pointer-events-none absolute -top-24 -right-24 opacity-[0.06]">
			<svg width="560" height="560" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="text-[#1a1a1a]">
				<path fill="currentColor" d="M40.5,-69.5C52.7,-62.4,63.1,-52.6,70.7,-40.2C78.3,-27.7,83.1,-12.5,83.7,3.4C84.4,19.3,80.9,36,72.2,49.2C63.5,62.3,49.6,72,34.4,76.5C19.1,81,2.4,80.3,-13.4,75.6C-29.2,70.9,-44.2,62.3,-56.6,50.5C-69,38.8,-78.8,23.8,-81.1,7.1C-83.5,-9.6,-78.4,-27.1,-68.2,-40.5C-58,-53.9,-42.7,-63.2,-26.5,-69.4C-10.3,-75.6,6.8,-78.6,21.8,-76.6C36.8,-74.6,49.7,-67.7,40.5,-69.5Z"/>
			</svg>
		</div>
		<nav class="w-full py-8 px-6 md:px-16 lg:px-24 flex flex-col md:flex-row md:justify-between md:items-center gap-4 z-10 max-w-6xl mx-auto">
			<a href="/" class="text-xl md:text-2xl tracking-widest font-bold">CLAIRE ZHANG</a>
			<div class="flex flex-wrap gap-6 text-xs tracking-[0.25em] uppercase font-sans">
				<a href="/portfolio" class={`hover:text-[#c93a3a] transition-colors duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#c93a3a] ${path === 'portfolio' ? 'text-[#c93a3a]' : ''}`} aria-current={path === 'portfolio' ? 'page' : undefined}>Portfolio</a>
				<a href="/music" class={`hover:text-[#c93a3a] transition-colors duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#c93a3a] ${path === 'music' ? 'text-[#c93a3a]' : ''}`} aria-current={path === 'music' ? 'page' : undefined}>Music</a>
				<a href="/about" class={`hover:text-[#c93a3a] transition-colors duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#c93a3a] ${path === 'about' ? 'text-[#c93a3a]' : ''}`} aria-current={path === 'about' ? 'page' : undefined}>About</a>
			</div>
		</nav>
		<main id="main" class="flex-grow px-6 md:px-16 lg:px-24 pb-24 max-w-6xl mx-auto w-full">
			<slot />
		</main>
		<footer class="py-8 text-center text-xs text-[#7a736d] tracking-wider mt-auto border-t border-[#EDE8E1] mx-6 md:mx-16 lg:mx-24">
			<div class="flex items-center justify-center gap-3 mb-2">
				<span class="inline-flex items-center justify-center w-8 h-8 border border-[#c93a3a] text-[#c93a3a] font-sans text-[10px] tracking-[0.3em]">印</span>
				<span class="font-sans uppercase tracking-[0.25em] text-[10px]">Artist Seal</span>
			</div>
			© {new Date().getFullYear()} CLAIRE ZHANG. ALL RIGHTS RESERVED.
		</footer>
	</body>
</html>
<style is:global>
	body {
		font-family: 'Playfair Display', 'Noto Serif SC', serif;
	}
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Playfair Display', serif;
	}
	.nav-ui {
		font-family: 'Inter', sans-serif;
	}
</style>